// Prisma schema — Sistem HR
// Datasource: MySQL local. Atur DATABASE_URL di .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ RBAC: Role & Permission (bisa ditambah & diatur authority) ============

model Permission {
  id        Int              @id @default(autoincrement())
  key       String           @unique // contoh: "employees.create"
  label     String
  group     String // pengelompokan di UI, contoh: "Karyawan"
  roles     RolePermission[]
  createdAt DateTime         @default(now())
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false) // role bawaan tidak bisa dihapus
  color       String           @default("#6366f1")
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId Int

  @@id([roleId, permissionId])
}

// ============ Department (bisa ditambahkan) ============

model Department {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?
  users       User[]
  schedule    WorkSchedule?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ============ User / Karyawan ============

model User {
  id             Int       @id @default(autoincrement())
  username       String    @unique
  email          String?   @unique
  passwordHash   String
  fullName       String
  birthDate      DateTime?
  joinDate       DateTime  @default(now())
  photo          String?   @db.LongText // data URL foto profil (opsional)
  ktpPhoto       String?   @db.LongText // data URL foto KTP (opsional)
  address        String?   @db.Text // alamat lengkap
  emergencyName  String? // nama pemilik kontak darurat
  emergencyPhone String? // nomor telepon kontak darurat
  isActive       Boolean   @default(true)

  roleId       Int
  role         Role        @relation(fields: [roleId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  baseSalary           Float @default(0) // gaji pokok
  performanceAllowance Float @default(0) // tunjangan kinerja maksimal (dikali skor)

  attendances          Attendance[]
  leaveRequests        LeaveRequest[]        @relation("Requester")
  reviewedLeaves       LeaveRequest[]        @relation("Reviewer")
  performanceRecords   PerformanceRecord[]
  payrolls             Payroll[]
  assignedKpis         KpiMetric[]           @relation("UserKpis")
  taskLogs             TaskLog[]
  pdcaTasks            PdcaTask[]
  financialImports     FinancialImport[]
  financialComparisons FinancialComparison[]
  ticketsRequested     Ticket[]              @relation("TicketRequester")
  ticketsAssigned      Ticket[]              @relation("TicketAssignee")
  ticketComments       TicketComment[]       @relation("TicketCommentAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ Jam kerja & toleransi (per department, null = default global) ============

model WorkSchedule {
  id               Int         @id @default(autoincrement())
  departmentId     Int?        @unique // null = pengaturan default global
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  checkInTime      String      @default("08:00") // HH:mm
  checkOutTime     String      @default("17:00") // HH:mm
  lateToleranceMin Int         @default(15) // toleransi terlambat (menit)
  earlyLeaveTolMin Int         @default(0) // toleransi pulang cepat (menit)
  workDays         String      @default("1,2,3,4,5") // 0=Min ... 6=Sab
  updatedAt        DateTime    @updatedAt
}

// ============ Absensi ============

enum CheckInStatus {
  ON_TIME
  LATE
}

enum CheckOutStatus {
  ON_TIME
  EARLY_LEAVE
}

model Attendance {
  id             Int             @id @default(autoincrement())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  date           DateTime        @db.Date // tanggal absensi (unik per user per hari)
  checkInAt      DateTime?
  checkInStatus  CheckInStatus?
  checkInPhoto   String?         @db.LongText
  lateMinutes    Int             @default(0)
  checkOutAt     DateTime?
  checkOutStatus CheckOutStatus?
  checkOutPhoto  String?         @db.LongText
  earlyMinutes   Int             @default(0)
  workedMinutes  Int             @default(0)
  createdAt      DateTime        @default(now())

  @@unique([userId, date])
  @@index([date])
}

// ============ Cuti ============

enum LeaveType {
  ANNUAL // Cuti Tahunan
  SICK // Sakit
  PERMISSION // Izin
  UNPAID // Tanpa Gaji
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id           Int         @id @default(autoincrement())
  user         User        @relation("Requester", fields: [userId], references: [id], onDelete: Cascade)
  userId       Int
  type         LeaveType   @default(ANNUAL)
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String      @db.Text
  status       LeaveStatus @default(PENDING)
  reviewedBy   User?       @relation("Reviewer", fields: [reviewedById], references: [id])
  reviewedById Int?
  reviewedAt   DateTime?
  reviewNote   String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
}

// ============ Kinerja & Penggajian (pembobotan) ============

model KpiMetric {
  id           Int                 @id @default(autoincrement())
  name         String
  description  String?
  weight       Float               @default(0) // bobot (%) — total semua metric idealnya 100
  active       Boolean             @default(true)
  // Jika userId null = KPI umum (berlaku untuk semua karyawan).
  // Jika terisi = KPI khusus milik karyawan tersebut.
  userId       Int?
  assignedUser User?               @relation("UserKpis", fields: [userId], references: [id], onDelete: Cascade)
  records      PerformanceRecord[]
  createdAt    DateTime            @default(now())

  @@index([userId])
}

model PerformanceRecord {
  id        Int       @id @default(autoincrement())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  metric    KpiMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  metricId  Int
  period    String // YYYY-MM
  score     Float     @default(0) // capaian 0-100
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, metricId, period])
  @@index([period])
}

model Payroll {
  id                Int      @id @default(autoincrement())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            Int
  period            String // YYYY-MM
  baseSalary        Float
  performanceScore  Float // skor berbobot 0-100
  performanceAmount Float // tunjangan kinerja yang didapat
  deductions        Float    @default(0)
  totalSalary       Float
  note              String?  @db.Text
  generatedAt       DateTime @default(now())

  @@unique([userId, period])
}

// Penyimpanan konfigurasi/kredensial runtime (key-value). Dipakai a.l. untuk
// menyimpan token OAuth integrasi marketplace (TikTok Shop) yang di-refresh berkala.
model AppConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ============ Task Log Harian ============

enum TaskStatus {
  PLANNED // Direncanakan
  IN_PROGRESS // Dikerjakan
  DONE // Selesai
}

model TaskLog {
  id          Int        @id @default(autoincrement())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  date        DateTime   @db.Date // tanggal pekerjaan
  title       String
  description String?    @db.Text
  status      TaskStatus @default(DONE)
  hours       Float? // durasi jam (opsional)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, date])
  @@index([date])
}

// ============ Manajemen PDCA: checklist mingguan (Week -> Task per PIC) ============

enum PdcaTaskStatus {
  BELUM_SELESAI
  SELESAI
}

model PdcaWeek {
  id        Int        @id @default(autoincrement())
  title     String // mis. "Week 1"
  startDate DateTime?  @db.Date
  endDate   DateTime?  @db.Date
  tasks     PdcaTask[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([startDate])
}

model PdcaTask {
  id        Int            @id @default(autoincrement())
  week      PdcaWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weekId    Int
  title     String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade) // PIC
  userId    Int
  status    PdcaTaskStatus @default(BELUM_SELESAI)
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([weekId])
  @@index([userId])
}

// ============ Impor Data Keuangan (ekstraksi otomatis via AI dari file Excel/CSV) ============

enum FinancialImportStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum FinancialTransactionType {
  INCOME
  EXPENSE
}

model FinancialImport {
  id           Int                    @id @default(autoincrement())
  fileName     String
  uploadedBy   User                   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  uploadedById Int
  status       FinancialImportStatus  @default(PROCESSING)
  currency     String                 @default("IDR")
  totalIncome  Float                  @default(0)
  totalExpense Float                  @default(0)
  aiNotes      String?                @db.Text // catatan ringkas dari AI (ambiguitas, baris yang dilewati, dsb.)
  errorMessage String?                @db.Text
  transactions FinancialTransaction[]
  createdAt    DateTime               @default(now())

  @@index([uploadedById])
}

model FinancialTransaction {
  id          Int                      @id @default(autoincrement())
  import      FinancialImport          @relation(fields: [importId], references: [id], onDelete: Cascade)
  importId    Int
  date        DateTime                 @db.Date
  description String
  category    String
  type        FinancialTransactionType
  amount      Float
  notes       String?                  @db.Text
  createdAt   DateTime                 @default(now())

  @@index([importId])
  @@index([date])
}

// Hasil komparasi keuangan (dibuat oleh Asisten AI Keuangan lewat chat) antara
// dua ruang lingkup — mis. dua periode, atau dua data impor — beserta insight-nya.
model FinancialComparison {
  id            Int      @id @default(autoincrement())
  title         String
  scopeALabel   String // deskripsi ruang lingkup A, mis. "Juni 2026" atau "Impor #3"
  scopeBLabel   String
  totalIncomeA  Float    @default(0)
  totalExpenseA Float    @default(0)
  totalIncomeB  Float    @default(0)
  totalExpenseB Float    @default(0)
  analysis      String   @db.Text // ringkasan/insight komparasi dari AI
  createdBy     User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById   Int
  createdAt     DateTime @default(now())

  @@index([createdById])
}

// ============ Ticketing System (helpdesk internal) ============

enum TicketStatus {
  OPEN // Baru dibuka, belum ditangani
  IN_PROGRESS // Sedang dikerjakan PIC
  RESOLVED // Sudah diselesaikan PIC
  CLOSED // Ditutup (dikonfirmasi pengaju / final)
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          Int            @id @default(autoincrement())
  title       String
  description String         @db.Text
  category    String         @default("Umum")
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)

  // Siapa yang mengajukan tiket
  requester   User  @relation("TicketRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId Int
  // PIC yang ditugaskan menyelesaikan (opsional saat dibuat)
  assignee    User? @relation("TicketAssignee", fields: [assigneeId], references: [id])
  assigneeId  Int?

  dueDate        DateTime? @db.Date
  resolvedAt     DateTime?
  resolutionNote String?   @db.Text

  comments  TicketComment[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([requesterId])
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  Int
  author    User     @relation("TicketCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  authorId  Int
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([ticketId])
}
