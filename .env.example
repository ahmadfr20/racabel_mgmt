# ==== Database (MySQL local) ====
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Contoh XAMPP default (user root tanpa password):
DATABASE_URL="mysql://root:@localhost:3306/hrapp"

# ==== Auth ====
# Ganti dengan string acak yang panjang untuk produksi
JWT_SECRET="ganti-dengan-secret-acak-minimal-32-karakter-panjang"

# Umur sesi (dalam detik) - default 8 jam
SESSION_MAX_AGE=28800
